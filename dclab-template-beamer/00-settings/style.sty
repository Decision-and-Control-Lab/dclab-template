\addtobeamertemplate{frametitle continuation}{ (\hspace{-1mm}}{)}

\setbeamercolor{alerted text}{fg=BlueGreen, bg=BlueGreen}
\setbeamercolor{frametitle}{parent=structure}
\setbeamercolor{title separator}{fg=BlueGreen}
\setbeamercolor{progress bar in section page}{fg=BlueGreen}
\setbeamercolor{frame footer}{parent=structure}

\setbeamerfont{page number in head/foot}{size=\tiny}
\setbeamerfont{footline}{size=\tiny}
\setbeamerfont{title}{size = \large}
\setbeamerfont{subtitle}{size = \normalsize}
\setbeamerfont{author}{size = \small}

\setbeamertemplate{date}{
\vspace*{5mm}
\insertdate%
\par%
}

\setbeamertemplate{institute}{
\vspace*{0.5em}
\insertinstitute%
\par%
}

\setbeamertemplate{title}{
 \vspace*{2em}
  \raggedright%
  \linespread{1.0}%
  \textcolor{BlueGreen}{\textbf{\inserttitle}}%
  \par%
  \vspace*{0.5em}
}
\setbeamertemplate{subtitle}{
  \raggedright%
  \textit{\insertsubtitle}%
  \par%
}

\setbeamertemplate{author}{
  \vspace*{0.5em}
  \insertauthor%
  \par%
  \vspace*{0.25em}
}

\setbeamertemplate{title page}{
  \begin{minipage}[b][\paperheight]{\textwidth}
    \ifx\inserttitlegraphic\@empty\else\usebeamertemplate*{title graphic}\fi
    \vfill%
    \ifx\inserttitle\@empty\else\usebeamertemplate*{title}\fi
    \ifx\insertsubtitle\@empty\else\usebeamertemplate*{subtitle}\fi
    \usebeamertemplate*{title separator}
    \ifx\beamer@shortauthor\@empty\else\usebeamertemplate*{author}\fi
    \ifx\insertinstitute\@empty\else\usebeamertemplate*{institute}\fi
    \ifx\insertdate\@empty\else\usebeamertemplate*{date}\fi
    {\scriptsize \textbf{Presenting author:} \insertshortauthor}
    % 
    \vspace*{10mm}
  \end{minipage}
}
