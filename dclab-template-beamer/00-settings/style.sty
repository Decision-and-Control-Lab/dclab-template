% LOGHI IN BASSO A DESTRA (su ogni slide)
% Disegnati in TikZ cosi' che il numero di loghi sia scelto
% liberamente dallo studente: basta cambiare la lista \loghi in
% main.tex (vedi CONFIGURA QUI). Il resto dell'aspetto della slide
% (colori, riquadri, linee di avanzamento) e' gia' fornito dal tema
% Metropolis: non aggiungiamo altri elementi decorativi per non
% entrare in conflitto con il suo stile.
% ---------------------------------------------------------------
\RequirePackage{tikz}
\usetikzlibrary{calc}

% Lista di loghi di default (separati da virgola, nessun limite al numero).
% Per non mostrare alcun logo: \renewcommand{\loghi}{}
\providecommand{\loghi}{00-settings/LogoPoliBa.png,00-settings/LogoDandC.png,00-settings/dmmm.png}

\setbeamertemplate{background}{
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, xshift=-0.25cm, yshift=0.5cm] at (current page.south east) {
      \foreach \img in \loghi {\includegraphics[height=5.5mm]{\img}\hspace{3mm}}
    };
  \end{tikzpicture}
}
\defbeamertemplate*{frametitle}{myframetitle}{%
    \nointerlineskip
    \begin{beamercolorbox}[%
        wd=\paperwidth,%
        sep=0pt,%
        leftskip=\metropolis@frametitle@padding,
        rightskip=\metropolis@frametitle@padding,
        ignorebg,
        ]{frametitle}%
        \metropolis@frametitlestrut@start
        \insertframetitle
        \nolinebreak
        \metropolis@frametitlestrut@end
    \end{beamercolorbox}
}

